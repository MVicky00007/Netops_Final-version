{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "1. Discovery Server (Eureka)",
            "request": "launch",
            "mainClass": "com.project.netops.discovery.DiscoveryServerApplication",
            "projectName": "discovery-server"
        },
        {
            "type": "java",
            "name": "2. API Gateway",
            "request": "launch",
            "mainClass": "com.project.netops.gateway.ApiGatewayApplication",
            "projectName": "api-gateway"
        },
        {
            "type": "java",
            "name": "3. User Service",
            "request": "launch",
            "mainClass": "com.project.netops.UserServiceApplication",
            "projectName": "user-service"
        },
        {
            "type": "java",
            "name": "4. Site Service",
            "request": "launch",
            "mainClass": "com.project.netops.SiteServiceApplication",
            "projectName": "site-service"
        },
        {
            "type": "java",
            "name": "5. Incident Service",
            "request": "launch",
            "mainClass": "com.project.netops.IncidentServiceApplication",
            "projectName": "incident-service"
        },
        {
            "type": "java",
            "name": "6. Capacity Service",
            "request": "launch",
            "mainClass": "com.project.netops.CapacityServiceApplication",
            "projectName": "capacity-service"
        },
        {
            "type": "java",
            "name": "7. Task Service",
            "request": "launch",
            "mainClass": "com.project.netops.TaskServiceApplication",
            "projectName": "task-service"
        }
    ],
    "compounds": [
        {
            "name": "All microservices (full stack)",
            "configurations": [
                "1. Discovery Server (Eureka)",
                "2. API Gateway",
                "3. User Service",
                "4. Site Service",
                "5. Incident Service",
                "6. Capacity Service",
                "7. Task Service"
            ],
            "stopAll": true
        }
    ]
}
